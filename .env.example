# Autonomous Forge - Environment Variables
# Duplicate this file as .env and fill in the values.

# LLM Providers Configuration
# Options: gemini, groq, sambanova, cerebras, mistral, openrouter, deepinfra
PRIMARY_LLM=gemini

# Options: generate, chat
MODE=generate

# API Keys (Provide at least two as fallback)
# Gemini: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# SambaNova: https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=your_sambanova_api_key_here

# Cerebras: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Mistral: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# DeepInfra: https://deepinfra.com/dash/api_keys
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# GitHub Automation
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=MauricioOpenClaw

# Sandbox Config
DOCKER_IMAGE=autonomous-forge-sandbox
STORAGE_PATH=./storage
